---
import Testimonials from "@/components/landing/Testimonials.astro";
import BgGrid from "@/components/assets/BgGrid.astro";
---

<section class="border-white/10 border-b bg-[#0a0a0a]">
  <div class="p-8 md:p-16 relative overflow-hidden">
    <BgGrid />

    <div class="relative z-10 max-w-6xl">
      <p class="text-[#ff5f1f] font-mono text-xs mb-6 tracking-[0.3em] uppercase opacity-80">
        About me // 2026
      </p>
      
      <h1 class="text-white tracking-tight font-bold text-5xl lg:text-9xl mb-12 leading-[0.8]">
        SOC Automation Engineer
      </h1>

      <h2 class="text-white tracking-tight font-bold text-3xl lg:text-6xl mb-8 leading-[1.1] uppercase">
        I build automation systems that align IT operations with <span class="text-[#ff5f1f]">advanced security monitoring.</span>
      </h2>

      <p class="text-white/60 text-lg lg:text-2xl font-light max-w-4xl leading-relaxed">
        Leveraging AIOps and Zero-Trust frameworks to reduce downtime, and deploying <span class="text-white font-medium">resilient systems</span> that scale with AI workloads.
      </p>
    </div>
  </div>
  
</section>