---
import BgGrid from "@/components/assets/BgGrid.astro";
---

<section id="about" class="border-b border-white/10 bg-[#0a0a0a] overflow-hidden">
  <div class="p-8 md:p-16 relative">
    <BgGrid />
    
    <div class="relative z-10 max-w-5xl">
      <p class="text-[#ff5f1f] font-mono text-[10px] mb-8 tracking-[0.4em] uppercase opacity-60">
        // More About me
      </p>
      
      <div class="space-y-12">
        <h2 class="text-white text-4xl md:text-7xl font-black uppercase tracking-tighter leading-[0.85]">
          I BUILD PRACTICAL <span class="text-[#ff5f1f]">SECURITY SYSTEMS</span> THAT STRENGTHEN ENTERPRISE DEFENSES.
        </h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 pt-4">
          <div class="space-y-6">
            <p class="text-white/80 font-medium text-xl md:text-2xl leading-tight">
              I am <span class="text-white">Desmond Achusi</span>, a Nigeria-based ICT specialist and cybersecurity analyst working with NNPC Gas Marketing Limited.
            </p>
            <p class="text-white/50 text-base md:text-lg leading-relaxed uppercase tracking-wide">
              I build practical security systems that improve visibility, automate monitoring, and strengthen enterprise defenses from the ground up.
            </p>
          </div>

          <div class="space-y-6 border-l border-white/10 pl-8">
            <p class="text-white/50 text-base md:text-lg leading-relaxed uppercase tracking-wide">
              I work on detection engineering and security automation, designing SOC-style pipelines that turn raw operational data into real, actionable insights. I am hands-on, grounded, and focused on tools that reflect how security operations actually work.
            </p>
            <p class="text-[#ff5f1f] font-bold text-lg md:text-xl uppercase tracking-tighter">
              My goal is to bring this practical expertise to international cybersecurity teams working on detection engineering and resilient infrastructure.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>