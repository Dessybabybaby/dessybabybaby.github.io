---
import BgGrid from "@/components/assets/BgGrid.astro";

const metrics = [
  {
    value: 82,
    suffix: "%",
    label: "Security Monitoring Automation",
    description: "Automated vulnerability and threat intelligence ingestion through n8n pipelines.",
    type: "ring"
  },
  {
    value: 40,
    suffix: "+",
    label: "Threat Intel Enrichments",
    description: "Automated enrichment of alerts using MITRE ATT&CK mappings and reputation feeds.",
    type: "bar"
  },
  {
    value: 15,
    suffix: "+",
    label: "Credential Exposure Patterns",
    description: "Detection logic scanning repositories for exposed secrets and API tokens.",
    type: "scan"
  }
];

const circumference = 2 * Math.PI * 80;
const offset = circumference - (metrics[0].value / 100) * circumference;
---

<section class="border-b border-white/10 bg-[#0a0a0a] overflow-hidden">
  <div class="p-8 md:p-16 relative">

    <BgGrid />

    <div class="relative z-10">

      <p class="text-[#ff5f1f] font-mono text-[10px] mb-4 tracking-[0.4em] uppercase opacity-60">
        // Security Automation Metrics
      </p>

      <h2 class="text-white font-bold uppercase tracking-tighter lg:text-7xl text-3xl leading-none mb-16">
        OPERATIONAL <span class="text-[#ff5f1f]">KPIs.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

        <!-- Ring KPI -->
        <div class="flex flex-col items-center text-center group">

          <div class="relative h-48 w-48 mb-6 flex items-center justify-center">

            <svg class="h-full w-full transform -rotate-90">
              <circle
                cx="96"
                cy="96"
                r="80"
                stroke="currentColor"
                stroke-width="4"
                fill="transparent"
                class="text-white/5"
              />

              <circle
                cx="96"
                cy="96"
                r="80"
                stroke="#ff5f1f"
                stroke-width="4"
                fill="transparent"
                stroke-dasharray={circumference}
                stroke-dashoffset={offset}
                class="transition-all duration-1000 group-hover:stroke-white"
              />
            </svg>

            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-5xl font-black text-white">
                {metrics[0].value}{metrics[0].suffix}
              </span>
            </div>

          </div>

          <p class="text-[#ff5f1f] font-mono text-xs uppercase tracking-widest mb-2">
            {metrics[0].label}
          </p>

          <p class="text-white/40 text-[10px] uppercase max-w-[200px]">
            {metrics[0].description}
          </p>

        </div>

        <!-- Bar KPI -->
        <div class="flex flex-col justify-center group">

          <div class="space-y-6 mb-8">

            <p class="text-white/40 font-mono text-[10px] uppercase">
              Alert Processing Trend
            </p>

            <div class="h-32 flex items-end gap-2 border-b border-white/10 pb-2">

              {[50, 65, 40, 75, 90].map((h, i) => (

                <div
                  class={`flex-1 transition-all duration-700 ${
                    i === 4
                      ? "bg-[#ff5f1f]"
                      : "bg-white/10 group-hover:bg-white/20"
                  }`}
                  style={`height: ${h}%`}
                />

              ))}

            </div>

          </div>

          <p class="text-[#ff5f1f] font-mono text-xs uppercase tracking-widest mb-2">
            {metrics[1].value}{metrics[1].suffix} {metrics[1].label}
          </p>

          <p class="text-white/40 text-[10px] uppercase">
            {metrics[1].description}
          </p>

        </div>

        <!-- Scan KPI -->
        <div class="flex flex-col items-center text-center group">

          <div class="relative h-48 w-48 mb-6 border border-white/10 rounded-full flex items-center justify-center overflow-hidden">

            <div class="absolute inset-0 bg-gradient-to-tr from-[#ff5f1f]/20 to-transparent origin-center animate-spin-slow"></div>

            <div class="absolute inset-0 flex items-center justify-center">

              <div class="w-full h-[1px] bg-white/5"></div>
              <div class="h-full w-[1px] bg-white/5"></div>
              <div class="w-24 h-24 rounded-full border border-white/5"></div>

            </div>

            <span class="relative z-10 text-5xl font-black text-white">
              {metrics[2].value}{metrics[2].suffix}
            </span>

          </div>

          <p class="text-[#ff5f1f] font-mono text-xs uppercase tracking-widest mb-2">
            {metrics[2].label}
          </p>

          <p class="text-white/40 text-[10px] uppercase max-w-[200px]">
            {metrics[2].description}
          </p>

        </div>

      </div>
    </div>
  </div>
</section>

<style>
@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.animate-spin-slow {
  animation: spin-slow 6s linear infinite;
}
</style>